#!/bin/sh
set -eu
RMINIBWA_PACKAGE_ROOT=${RMINIBWA_PACKAGE_ROOT:-$(pwd)}
export RMINIBWA_PACKAGE_ROOT
RMINIBWA_MAKEVARS_IN=${RMINIBWA_MAKEVARS_IN:-src/Makevars.win.in}
RMINIBWA_MAKEVARS_OUT=${RMINIBWA_MAKEVARS_OUT:-src/Makevars.win}
export RMINIBWA_MAKEVARS_IN RMINIBWA_MAKEVARS_OUT
"$RMINIBWA_PACKAGE_ROOT/tools/configure-rminibwa-dispatch.sh"
