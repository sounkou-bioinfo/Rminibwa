Package: Rminibwa
Title: Native R Bindings and SIMD Dispatch for 'minibwa'
Version: 0.0.0.9000
Authors@R: c(
    person(given = "Sounkou Mahamane", family = "Toure",
      email = "sounkoutoure@gmail.com", role = c("aut", "cre")),
    person(given = "Dana-Farber Cancer Institute", role = "cph",
      comment = "Copyright holder of upstream minibwa"),
    person(given = "Ilya", family = "Grebnov", role = "cph",
      comment = "libsais copyright holder"),
    person(given = "N. Jesper", family = "Larsson", role = "cph",
      comment = "QSufSort copyright holder"),
    person(given = "Wong", family = "Chi Kwong", role = "cph",
